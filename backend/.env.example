## Backend service env (local/dev)
## Auth uses Redis-only live sessions (no JWT).

REDIS_URL=redis://localhost:6379
SESSION_TTL=10d
PORT=8000

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Local Postgres (docker-compose.local.yml maps host port 5433)
DATABASE_URL=postgresql://postgres:1234@localhost:5432/hall_db

PAYMENT_SERVER_URL=http://localhost:8080
PAY_SERVICE_SECRET=

BREVO_SMTP_HOST=
BREVO_SMTP_PORT=465
BREVO_SMTP_USER=
BREVO_SMTP_PASS=
EMAIL_FROM=

STUDENT_URL=http://localhost:3001
ADMIN_URL=http://localhost:4001
