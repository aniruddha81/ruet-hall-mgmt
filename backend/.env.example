## Backend .env — LOCAL development (npm run dev on host, no Docker for apps)
## Production uses root .env + Docker Compose — see ENV_AND_RUN.md
## Auth uses Redis-only live sessions (no JWT).

REDIS_URL=redis://localhost:6379
SESSION_TTL=10d
PORT=8000

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Postgres: use host port 5433 when DB runs via docker-compose.local.yml
# Use same user/password as POSTGRES_* in root .env
DATABASE_URL=postgresql://postgres:change-me@localhost:5433/hall_db

SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_IS_SANDBOX=true
API_PUBLIC_URL=http://localhost:8000

BREVO_SMTP_HOST=
BREVO_SMTP_PORT=465
BREVO_SMTP_USER=
BREVO_SMTP_PASS=
EMAIL_FROM=

STUDENT_URL=http://localhost:3001
ADMIN_URL=http://localhost:4001
