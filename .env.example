# Copy to .env at repo root (only env file for the whole monorepo).

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=hall_db
DATABASE_URL=postgresql://postgres:change-me@localhost:5432/hall_db

BACKEND_PORT=8000
PORT=8000
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

BACKEND_API_URL=http://localhost:8000

API_PUBLIC_URL=https://api.yourdomain.com
STUDENT_URL=https://app.yourdomain.com
ADMIN_URL=https://admin.yourdomain.com

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Use the exact URL from Redis Cloud (redis:// or rediss:// — not both)
REDIS_URL=redis://default:YOUR_PASSWORD@YOUR_HOST.redis.cloud:PORT
SESSION_TTL=10d

SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_IS_SANDBOX=true

BREVO_SMTP_HOST=
BREVO_SMTP_PORT=465
BREVO_SMTP_USER=
BREVO_SMTP_PASS=
EMAIL_FROM=

NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=
