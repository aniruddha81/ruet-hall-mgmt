# Root .env — PRODUCTION Docker Compose (docker-compose.yml) on the VM.
# For local npm run dev, use backend/.env + web/.env.local + admin/.env.local instead (see ENV_AND_RUN.md).

# Database (PostgreSQL 18, Docker image postgres:18.4-alpine)
# Used by docker-compose.yml (and optionally docker-compose.local.yml)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=hall_db

# Port Configuration
BACKEND_PORT=8000
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Routing
BACKEND_API_URL=http://localhost:8000
STUDENT_URL=http://localhost:3001
ADMIN_URL=http://localhost:4001

# Cloudinary (Image Storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Live sessions (Redis)
REDIS_URL=redis://localhost:6379
SESSION_TTL=10d

# SSLCommerz (sandbox: https://developer.sslcommerz.com/registration/)
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_IS_SANDBOX=true
API_PUBLIC_URL=http://localhost:8000

# Email (optional — Brevo SMTP)
BREVO_SMTP_HOST=
BREVO_SMTP_PORT=465
BREVO_SMTP_USER=
BREVO_SMTP_PASS=
EMAIL_FROM=

# Next.js (web + admin builds — generate once, keep stable in production)
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=
