# Database (MySQL 8.0)
MYSQL_ROOT_PASSWORD=your-root-password
MYSQL_DATABASE=hall_db
MYSQL_USER=halladmin
MYSQL_PASSWORD=your-db-pass

# Port Configuration
BACKEND_PORT=8000
PAYMENT_SERVER_PORT=8080
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Routing (Update with your production domains)
BACKEND_API_URL=https://api.example.com
STUDENT_URL=https://app.example.com
ADMIN_URL=https://admin.example.com

# Cloudinary (Image Storage)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# JWT Authentication
ACCESS_TOKEN_SECRET=your-long-random-string
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_SECRET=your-different-random-string
REFRESH_TOKEN_EXPIRY=10d

# Inter-service communication
PAY_SERVICE_SECRET=your-shared-secret-for-pay-service

# Next.js Secrets
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=your-encryption-key
