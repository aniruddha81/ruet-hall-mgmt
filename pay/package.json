{
  "name": "pay-server",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build ./src/index.ts --outdir dist --target bun",
    "start": "NODE_ENV=production bun run src/index.ts",
    "health-check": "bun -e \"const r=await fetch('http://127.0.0.1:8080/pay-api/meal-payment',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({studentId:'health',amount:1,totalQuantity:1,paymentMethod:'test'})}); if(!r.ok) process.exit(1);\""
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "prettier": "^3.8.1"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1"
  }
}
