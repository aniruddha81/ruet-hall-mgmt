{
  "name": "pay-server",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --noEmit",
    "start": "NODE_ENV=production tsx src/index.ts",
    "health-check": "node -e \"(async()=>{const r=await fetch('http://127.0.0.1:8080/pay-api/meal-payment',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({studentId:'health',amount:1,totalQuantity:1,paymentMethod:'test'})}); if(!r.ok) process.exit(1);})().catch(()=>process.exit(1));\""
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "prettier": "^3.8.2",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "tsx": "^4.21.0"
  }
